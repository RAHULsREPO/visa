<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-16">
        <div class="space-y-6">
          <h2 class="text-4xl font-heading font-bold text-primary">Who We Are</h2>
          <p class="text-slate-600 leading-relaxed">
            TrueGate Visa is your trusted partner in navigating the complexities of global immigration and consular regulations. Established in 2025, we specialize in high-success visa consultancy, meticulous documentation audit, and priority filing.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Based in Ernakulam, Kerala, our senior counselors assist students, working professionals, families, and businesses across India, ensuring their visa applications are fully compliant and streamlined for approval.
          </p>
        </div>
        <div class="relative">
          <img 
            src="https://images.unsplash.com/photo-1436491865332-7a61a109cc05?q=80&w=800&fit=crop" 
            alt="TrueGate Visa Office Consultation" 
            width={800}
            height={533}
            class="rounded-2xl shadow-2xl"
            loading="lazy"
          />
          <div class="absolute -bottom-6 -left-6 bg-accent text-primary p-6 rounded-xl shadow-xl">
            <p class="text-3xl font-bold">2025</p>
            <p class="text-sm font-medium">Established</p>
          </div>
        </div>
      </div>

      <div class="bg-slate-50 rounded-2xl p-8 md:p-12">
        <h3 class="text-3xl font-heading font-bold text-primary mb-6">Our Mission</h3>
        <p class="text-lg text-slate-700 leading-relaxed mb-4">
          To provide transparent, error-free visa filing support and immigration solutions through meticulous document audits, expert SOP reviews, and unwavering compliance with consular regulations.
        </p>
        <p class="text-slate-600 leading-relaxed">
          We believe in turning global aspirations into achievable realities with transparency, efficiency, and customized advisory at every step of the visa process.
        </p>
      </div>
    </div>
  </div>
</section>
