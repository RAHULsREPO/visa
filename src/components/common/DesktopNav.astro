---
import { desktopNavLinks } from '../../data/navigation';

const currentPath = Astro.url.pathname;
const isActive = (path: string) => {
	if (path === '/' && currentPath === '/') return true;
	if (path !== '/' && currentPath.startsWith(path)) return true;
	return false;
};
---

<nav class="hidden md:flex items-center gap-8">
	{desktopNavLinks.map(link => {
		const isAnchorLink = link.href.includes('#');
		const active = isAnchorLink ? false : isActive(link.href);

		return (
			<a 
				href={link.href} 
				class={`relative pb-1 text-base font-semibold transition-all duration-300 focus-visible:rounded-sm ${active ? 'text-accent after:w-full' : 'text-slate-700 hover:text-accent after:w-0'} after:absolute after:bottom-0 after:left-0 after:h-0.5 after:bg-accent after:transition-all after:duration-300 hover:after:w-full`}
			>
				{link.label}
			</a>
		);
	})}
</nav>
