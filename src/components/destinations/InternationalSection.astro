---
import DestinationCard from './DestinationCard.astro';

const internationalDestinations = [
  { 
    title: "United States (USA) Visa", 
    image: "/assets/images/usa.jpg", 
    desc: "B1/B2 tourist & business visa documentation support with profile evaluations and mock interview practice.", 
    link: "/#eligibility-checker" 
  },
  { 
    title: "United Kingdom (UK) Visa", 
    image: "https://images.unsplash.com/photo-1486299267070-8382e214434b?q=80&w=600&h=400&fit=crop", 
    desc: "Complete visitor visa application support, personalized checklist creation, and rigorous draft file auditing.", 
    link: "/#eligibility-checker" 
  },
  { 
    title: "Canada Visa", 
    image: "/assets/images/canada.jpg", 
    desc: "Visitor and super visa financial verification audits, ITR audits, and travel history profiling strategies.", 
    link: "/#eligibility-checker" 
  },
  { 
    title: "Schengen Area (Europe) Visa", 
    image: "https://images.unsplash.com/photo-1552832230-c0197dd311b5?q=80&w=600&h=400&fit=crop", 
    desc: "Schengen-compliant itinerary planning, medical insurance coordination, hotel vouchers, and cover letter audits.", 
    link: "/#eligibility-checker" 
  },
  { 
    title: "Australia Visa", 
    image: "https://images.unsplash.com/photo-1523482580672-f109ba8cb9be?q=80&w=600&h=400&fit=crop", 
    desc: "Subclass 600 visitor visa processing with strong home-ties alignment and documentation checks.", 
    link: "/#eligibility-checker" 
  },
  { 
    title: "Japan Visa", 
    image: "/assets/images/japan.jpg", 
    desc: "Structured short-term tourist visa preparation, day-by-day travel schedule checks, and checklist filings.", 
    link: "/#eligibility-checker" 
  },
  { 
    title: "South Korea Visa", 
    image: "/assets/images/south-korea.jpg", 
    desc: "C-3 tourist visa profile review, invitation checks (if applicable), and clean embassy dossier mapping.", 
    link: "/#eligibility-checker" 
  },
  { 
    title: "New Zealand Visa", 
    image: "/assets/images/new-zealand.jpg", 
    desc: "Profile-led visitor visa support, online application submission checks, and financial documentation drafting.", 
    link: "/#eligibility-checker" 
  },
  { 
    title: "Russia Visa", 
    image: "/assets/images/russia.jpg", 
    desc: "Tourist visa filing support, voucher validation, registration requirements guidance, and complete dossier audit.", 
    link: "/#eligibility-checker" 
  },
  { 
    title: "South Africa Visa", 
    image: "/assets/images/south-africa.jpg", 
    desc: "Tourist and visitor visa preparation, medical coverage verification, and checklist-based document filing.", 
    link: "/#eligibility-checker" 
  }
];
---

<section id="international-visas" class="py-20 bg-slate-50">
  <div class="container mx-auto px-4">
    <div class="mb-12 text-center md:text-left">
      <h2 class="text-3xl font-heading font-bold text-primary flex items-center justify-center md:justify-start gap-3">
         <span class="w-2 h-12 bg-accent rounded-full block"></span>
         Visitor Visa Pathways
      </h2>
      <p class="text-slate-600 mt-2 ml-5">Embassy-aligned documentation and filing support for top travel destinations.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {internationalDestinations.map(dest => (
        <DestinationCard 
          title={dest.title} 
          image={dest.image} 
          desc={dest.desc} 
          link={dest.link} 
          layout="grid" 
        />
      ))}
    </div>
  </div>
</section>
