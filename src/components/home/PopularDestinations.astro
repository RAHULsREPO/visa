---
import DestinationCard from './DestinationCard.astro';

const destinations = [
  {
    title: "United States",
    image: "https://images.unsplash.com/photo-1518235506717-e1ed3306a89b?q=80&w=600&h=400&fit=crop",
    link: "/destinations#international-visas",
    subtitle: "B1/B2 Tourist & Business Visas"
  },
  {
    title: "United Kingdom",
    image: "https://images.unsplash.com/photo-1513635269975-59663e0ac1ad?q=80&w=600&h=400&fit=crop",
    link: "/destinations#international-visas",
    subtitle: "Standard Visitor & Family Visas"
  },
  {
    title: "Canada",
    image: "https://images.unsplash.com/photo-1509023464722-18d996393ca8?q=80&w=600&h=400&fit=crop",
    link: "/destinations#international-visas",
    subtitle: "Visitor & Super Visa Filings"
  },
  {
    title: "Schengen Area",
    image: "https://images.unsplash.com/photo-1502602898657-3e91760cbb34?q=80&w=600&h=400&fit=crop",
    link: "/destinations#international-visas",
    subtitle: "Multi-Country Tourist & Business Visas"
  },
  {
    title: "Australia",
    image: "https://images.unsplash.com/photo-1506973035872-a4ec16b8e8d9?q=80&w=600&h=400&fit=crop",
    link: "/destinations#international-visas",
    subtitle: "Subclass 600 Visitor Visas"
  },
  {
    title: "Japan",
    image: "https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?q=80&w=600&h=400&fit=crop",
    link: "/destinations#international-visas",
    subtitle: "Tourist & Short-term Visas"
  },
  {
    title: "South Korea",
    image: "https://images.unsplash.com/photo-1538481199705-c710c4e965fc?q=80&w=600&h=400&fit=crop",
    link: "/destinations#international-visas",
    subtitle: "C-3 Tourist & Visit Visas"
  },
  {
    title: "New Zealand",
    image: "https://images.unsplash.com/photo-1508739773434-c26b3d09e071?q=80&w=600&h=400&fit=crop",
    link: "/destinations#international-visas",
    subtitle: "Visitor & Tourist Visa support"
  }
];
---

<section id="popular-destinations" class="section-pad relative overflow-hidden bg-[linear-gradient(180deg,#f8fbff_0%,#ffffff_45%,#fffaf0_100%)]">
  <div class="pointer-events-none absolute -left-16 top-12 h-48 w-48 rounded-full bg-primary/10 blur-3xl"></div>
  <div class="pointer-events-none absolute -right-20 bottom-0 h-56 w-56 rounded-full bg-accent/25 blur-3xl"></div>
  <div class="container mx-auto px-4">
    <div class="text-center mb-12 max-w-3xl mx-auto relative z-10">
      <span class="inline-flex items-center py-2 px-4 rounded-full border border-primary/20 bg-white text-primary font-semibold text-xs tracking-[0.16em] uppercase mb-4">
        Destinations
      </span>
      <h2 class="text-4xl md:text-5xl font-display font-bold text-primary-dark tracking-tight leading-tight mb-4">
        Popular Visa & Immigration Countries
      </h2>
      <p class="text-lg text-slate-600 leading-relaxed">
        Explore structured visa pathways, detailed criteria checklists, and success records for these high-demand global destinations.
      </p>
    </div>

    <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {destinations.map((dest) => (
        <DestinationCard {...dest} />
      ))}
    </div>
  </div>
</section>
