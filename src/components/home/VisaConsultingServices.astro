---
import { ArrowUpRight } from 'lucide-react';

const services = [
  {
    title: 'USA Tourist Visa',
    description: 'B1/B2 documentation support with profile checks and interview preparation.',
    image: 'https://images.unsplash.com/photo-1518235506717-e1ed3306a89b?q=80&w=1400&auto=format&fit=crop',
    link: '/contact'
  },
  {
    title: 'UK Visitor Visa',
    description: 'Complete visitor visa file support with clear checklist and document review.',
    image: 'https://images.unsplash.com/photo-1513635269975-59663e0ac1ad?q=80&w=1400&auto=format&fit=crop',
    link: '/contact'
  },
  {
    title: 'Canada Visitor Visa',
    description: 'Financial review and travel-history positioning to improve application quality.',
    image: 'https://images.unsplash.com/photo-1517411032315-54ef2cb783bb?q=80&w=1400&auto=format&fit=crop',
    link: '/contact'
  },
  {
    title: 'Schengen Visa',
    description: 'Itinerary, insurance, and cover-letter guidance for multi-country travel plans.',
    image: 'https://images.unsplash.com/photo-1502602898657-3e91760cbb34?q=80&w=1400&auto=format&fit=crop',
    link: '/contact'
  },
  {
    title: 'Australia Tourist Visa',
    description: 'Subclass 600 visitor visa support with profile alignment and document strategy.',
    image: 'https://images.unsplash.com/photo-1523482580672-f109ba8cb9be?q=80&w=1400&auto=format&fit=crop',
    link: '/contact'
  },
  {
    title: 'Japan Tourist Visa',
    description: 'Purpose and itinerary guidance with accurate checklist-based document filing.',
    image: 'https://images.unsplash.com/photo-1503899036084-c55cdd92da26?q=80&w=1400&auto=format&fit=crop',
    link: '/contact'
  },
  {
    title: 'South Korea Visit Visa',
    description: 'Visitor visa file preparation with eligibility checks and clean documentation.',
    image: 'https://images.unsplash.com/photo-1518005020951-eccb494ad742?q=80&w=1400&auto=format&fit=crop',
    link: '/contact'
  },
  {
    title: 'New Zealand Visitor Visa',
    description: 'Profile-led visa assistance with complete paperwork review and submission support.',
    image: 'https://images.unsplash.com/photo-1475924156734-496f6cac6ec1?q=80&w=1400&auto=format&fit=crop',
    link: '/contact'
  }
];
---

<section id="visa-services" class="py-20 bg-transparent relative">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="mb-14 text-center md:text-left md:max-w-2xl">
      <span class="inline-flex items-center rounded-full border border-primary/20 bg-primary/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-primary">
        Destination Services
      </span>
      <h2 class="mt-4 font-heading text-3xl font-black leading-tight text-slate-900 md:text-5xl">
        Expert Visa Support Routes
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate-600 md:text-lg">
        We specialize in guiding visitor and tourist visa paperwork for high-demand global destinations. Share your profile and destination goal with us.
      </p>
    </div>

    <div class="flex flex-col gap-8">
      {services.map((service) => (
        <article class="reveal glass-light shine-card group relative overflow-hidden rounded-[26px] border border-slate-200/50 transition-all duration-300 shadow-md shadow-slate-100/50 hover:shadow-xl hover:shadow-primary/5">
          <div class="grid grid-cols-1 md:grid-cols-[1fr_0.95fr] min-h-[300px]">
            <div class="flex flex-col justify-between p-6 md:p-8">
              <div>
                <h3 class="text-2xl md:text-3xl font-black tracking-tight text-slate-950 group-hover:text-primary transition-colors duration-300">
                  {service.title}
                </h3>
                <p class="mt-3 max-w-[480px] text-sm md:text-base leading-relaxed text-slate-600">
                  {service.description}
                </p>
              </div>
              <a 
                class="mt-6 inline-flex w-fit items-center gap-2 rounded-[14px] bg-primary hover:bg-primary-light hover:shadow-[0_0_18px_rgba(21,69,154,0.35)] px-6 py-3 text-xs font-semibold uppercase tracking-[0.15em] text-white transition-all duration-300 hover:-translate-y-0.5" 
                href={service.link}
              >
                <span>Check Requirements</span>
                <ArrowUpRight size={15} />
              </a>
            </div>
            <div class="p-6 pt-0 md:p-6 md:pl-0">
              <div class="relative h-[200px] md:h-full overflow-hidden rounded-[22px] border border-slate-200/50 shadow-lg">
                <div 
                  class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" 
                  style={`background-image: url(${service.image})`}
                ></div>
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/20 to-transparent"></div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
