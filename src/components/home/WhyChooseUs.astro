---
import { ShieldCheck, Award, Users, Zap } from 'lucide-react';

const highlights = [
  {
    title: 'Transparent Process',
    description: 'Clear communication from intake to final file submission.',
    icon: ShieldCheck
  },
  {
    title: 'Ethical Documentation',
    description: 'Accurate paperwork with practical advice and no false claims.',
    icon: Award
  },
  {
    title: 'Experienced Consultants',
    description: 'Team guidance built from years of Kerala visa documentation work.',
    icon: Users
  },
  {
    title: 'High Consistency',
    description: 'A repeatable process that improves application quality and clarity.',
    icon: Zap
  }
];
---

<section id="why-choose-us" class="py-20 bg-[#102147] border-y border-white/10 relative overflow-hidden">
  <!-- Glowing effects -->
  <div class="absolute -right-20 top-0 h-56 w-56 rounded-full bg-white/5 blur-[90px]"></div>
  <div class="absolute -bottom-24 left-20 h-60 w-60 rounded-full bg-accent/10 blur-[90px]"></div>

  <div class="container mx-auto px-4 max-w-6xl relative z-10">
    <div class="grid items-start gap-12 lg:grid-cols-[0.92fr_1.08fr]">
      
      <!-- Left Column: Sticky Title & Description -->
      <div class="lg:sticky lg:top-28 space-y-6">
        <div class="reveal-left glass-dark shine-card rounded-3xl p-6 md:p-8 space-y-5">
          <span class="text-[10px] font-bold uppercase tracking-[0.26em] text-accent">
            Why TrueGate
          </span>
          <h2 class="text-3xl md:text-5xl font-heading font-black leading-[1.05] tracking-tight text-white">
            Built for clear strategy and stronger documentation outcomes.
          </h2>
          <p class="text-sm md:text-base leading-relaxed text-slate-300">
            We combine practical profile planning, structured checks, and transparent support so each application is prepared with consistency.
          </p>
          <p class="text-sm md:text-base leading-relaxed text-slate-300">
            Our process is designed to reduce avoidable file errors and improve clarity before final submission.
          </p>
        </div>
      </div>

      <!-- Right Column: Value Stack -->
      <div class="space-y-6">
        {highlights.map((item) => {
          const IconComp = item.icon;
          return (
            <article class="reveal-right glass-dark shine-card rounded-2xl p-6 md:p-8 border border-white/10 hover:border-accent/30 transition-all duration-300">
              <div class="flex items-center gap-4 mb-4">
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-accent/20 text-accent">
                  <IconComp size={22} />
                </div>
                <h3 class="text-xl md:text-2xl font-black text-white tracking-tight">
                  {item.title}
                </h3>
              </div>
              <p class="text-sm md:text-base leading-relaxed text-slate-300">
                {item.description}
              </p>
            </article>
          );
        })}
      </div>

    </div>
  </div>
</section>
