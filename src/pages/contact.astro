---
import Layout from '../layouts/Layout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import ContactHero from '../components/contact/ContactHero.astro';
import ContactDetails from '../components/contact/ContactDetails.astro';
import ContactForm from '../components/contact/ContactForm.astro';
import GoogleMap from '../components/contact/GoogleMap.astro';
---

<Layout 
	title="Contact TrueGate Visa | Premium Visa Consultants Ernakulam"
	description="Get in touch with TrueGate Visa for expert visa guidance and document reviews. Visit our office in Ernakulam, Kerala or call +91-9720409020."
	keywords="contact TrueGate visa, visa consultants contact, Ernakulam office, student visa assistance, work permit consultants Kerala"
>
  <Header />

  <main>
    <ContactHero />
    
    <section class="py-20 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <ContactDetails />
          <ContactForm />
        </div>
      </div>
    </section>

    <GoogleMap />
  </main>

  <Footer />
</Layout>
